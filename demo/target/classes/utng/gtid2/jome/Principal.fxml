<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="680.0" prefWidth="1050.0" style="-fx-background-color: #DDE3EA;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="utng.gtid2.jome.PrimaryController">

    <left>
        <VBox prefWidth="190.0" style="-fx-background-color: #FFFFFF;">

            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 18 14 14 14; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
                <VBox alignment="CENTER" prefHeight="34.0" prefWidth="34.0" style="-fx-background-color: #4F7EF7; -fx-background-radius: 6;">
                    <children>
                        <ImageView fitHeight="45.0" fitWidth="53.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/Logo.png" />
                            </image>
                        </ImageView>
                    </children>
                </VBox>
                <VBox spacing="1.0">
                    <Label style="-fx-font-size: 10px; -fx-text-fill: #9CA3AF;" />
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1F2937;" text="CGTI" />
                </VBox>
            </HBox>

            <VBox spacing="2.0" style="-fx-padding: 10 8 8 8;" VBox.vgrow="ALWAYS">

                <Button fx:id="btnInicio" maxWidth="1.7976931348623157E308" onAction="#irAInicio" prefHeight="38.0" style="-fx-background-color: #EEF2FF; -fx-background-radius: 7; -fx-text-fill: #4F7EF7; -fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-border-width: 0;" text="  Inicio" />

                <Button fx:id="btnCatalogo" maxWidth="1.7976931348623157E308" onAction="#irACatalogo" prefHeight="38.0" style="-fx-background-color: transparent; -fx-background-radius: 7; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-border-width: 0;" text="  Catalogo" />

                <Button fx:id="btnAsignaciones" maxWidth="1.7976931348623157E308" onAction="#irAAsignaciones" prefHeight="38.0" style="-fx-background-color: transparent; -fx-background-radius: 7; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-border-width: 0;" text="  Asignaciones" />

                <Button fx:id="btnDesecho" maxWidth="1.7976931348623157E308" onAction="#irADesecho" prefHeight="38.0" style="-fx-background-color: transparent; -fx-background-radius: 7; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-border-width: 0;" text="  Desecho" />

                <Button fx:id="btnUsuarios" maxWidth="1.7976931348623157E308" onAction="#irAUsuarios" prefHeight="38.0" style="-fx-background-color: transparent; -fx-background-radius: 7; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-border-width: 0;" text="  Usuarios" />

                <Button fx:id="btnProveedores" maxWidth="1.7976931348623157E308" onAction="#irAProveedores" prefHeight="38.0" style="-fx-background-color: transparent; -fx-background-radius: 7; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-border-width: 0;" text="  Proveedores" />

                <Button fx:id="btnPrestamo" maxWidth="1.7976931348623157E308" onAction="#irAPrestamo" prefHeight="38.0" style="-fx-background-color: transparent; -fx-background-radius: 7; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-border-width: 0;" text="  Prestamo" />

                <Button fx:id="btnReportes" maxWidth="1.7976931348623157E308" onAction="#irAReportes" prefHeight="38.0" style="-fx-background-color: transparent; -fx-background-radius: 7; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-border-width: 0;" text="  Reportes" />

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="btnCerrarSesion" maxWidth="1.7976931348623157E308" onAction="#cerrarSesion" prefHeight="38.0" style="-fx-background-color: #C0392B; -fx-background-radius: 7; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-border-width: 0;" text="  Cerrar sesión" />
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="16.0" style="-fx-padding: 24 24 24 24; -fx-background-color: #DDE3EA;">

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblTitulo" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Panel principal" />
                    <Label fx:id="lblId" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="Bienvenido, jefe de area" />
                </VBox>
                <HBox alignment="CENTER" spacing="8.0">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1F2937;" text="Superusuario" />
                </HBox>
            </HBox>

            <GridPane hgap="14.0" vgap="0.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints />
                </rowConstraints>

                <VBox spacing="5.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-padding: 16 16 16 16;" GridPane.columnIndex="0">
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" text="Insumos registrados" />
                    <Label fx:id="lblInsumosRegistrados" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="86" />
                </VBox>

                <VBox spacing="5.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-padding: 16 16 16 16;" GridPane.columnIndex="1">
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" text="Insumos criticos" />
                    <Label fx:id="lblInsumosCriticos" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #EF4444;" text="7" />
                </VBox>

                <VBox spacing="5.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-padding: 16 16 16 16;" GridPane.columnIndex="2">
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" text="Tecnicos activos" />
                    <Label fx:id="lblTecnicosActivos" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="5" />
                </VBox>

                <VBox spacing="5.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-padding: 16 16 16 16;" GridPane.columnIndex="3">
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" text="Desecho del mes" />
                    <Label fx:id="lblDesechoMes" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="12.4 kg" />
                </VBox>
            </GridPane>

            <HBox alignment="CENTER_LEFT" spacing="24.0" style="-fx-background-color: #FEF2F2; -fx-background-radius: 10; -fx-border-color: #FECACA; -fx-border-width: 1; -fx-border-radius: 10; -fx-padding: 18 20 18 20;">
                <HBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">
                    <VBox alignment="CENTER" prefHeight="62.0" prefWidth="90.0" style="-fx-background-color: #FEF3C7; -fx-background-radius: 5; -fx-border-color: #F59E0B; -fx-border-width: 1; -fx-border-radius: 5;">
                        <children>
                            <ImageView fitHeight="65.0" fitWidth="86.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="@../images/Alerta.png" />
                                </image>
                            </ImageView>
                        </children>
                    </VBox>
                    <Label maxWidth="220.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #991B1B;" text="Alerta de desabasto: 7 insumos en nivel critico" wrapText="true" />
                </HBox>

                <VBox minWidth="270.0" spacing="0.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 7; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 7;">
                    <HBox style="-fx-padding: 8 12 8 12; -fx-border-color: transparent transparent #F3F4F6 transparent; -fx-border-width: 1;">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #374151;" text="Espuma limpiadora" HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="8 uds." />
                    </HBox>
                    <HBox style="-fx-padding: 8 12 8 12; -fx-background-color: #F9FAFB; -fx-border-color: transparent transparent #F3F4F6 transparent; -fx-border-width: 1;">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #374151;" text="Franela de microfibra" HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="5 uds." />
                    </HBox>
                    <HBox style="-fx-padding: 8 12 8 12;">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #374151;" text="Cable de red cat6" HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="10 uds." />
                    </HBox>
                </VBox>
            </HBox>

            <VBox spacing="0.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-padding: 18 18 6 18;">
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Actividad reciente">
                    <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                </Label>
                <Separator style="-fx-opacity: 0.5;" />
                <HBox style="-fx-padding: 12 0 12 0; -fx-border-color: transparent transparent #F3F4F6 transparent; -fx-border-width: 1;">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #374151;" text="Angel Nolasco registro salida de 2 memorias RAM" HBox.hgrow="ALWAYS" />
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;" text="hoy, 9:40" />
                </HBox>
                <HBox style="-fx-padding: 12 0 12 0;">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #374151;" text="Jonathan Aguilar reporto desecho de 3 latas de aerosol" HBox.hgrow="ALWAYS" />
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;" text="hoy, 8:15" />
                </HBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>